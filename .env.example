# ============================================================
# VARIÁVEIS DE AMBIENTE – E-commerce Vanessa Lima Shoes
# ============================================================
# Copie para .env e preencha com os valores reais.
# NUNCA commite o arquivo .env com valores reais.
#
# Variáveis VITE_ são expostas no browser (públicas).
# Segredos das Edge Functions são configurados via:
#   supabase secrets set NOME=VALOR
# ============================================================

# ------------------------------------------------------------
# SUPABASE (obrigatório – frontend + backend)
# ------------------------------------------------------------
# URL pública do projeto Supabase
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Anon key pública do Supabase (pode ser exposta no browser)
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ------------------------------------------------------------
# STRIPE (apenas Edge Functions – não expor no frontend)
# Configurar via: supabase secrets set STRIPE_SECRET_KEY=sk_...
# ------------------------------------------------------------
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PUBLISHABLE_KEY=pk_live_...  (esta pode ir no frontend se necessário)

# ------------------------------------------------------------
# YAMPI (apenas Edge Functions)
# Configurar via: supabase secrets set YAMPI_TOKEN=...
# ------------------------------------------------------------
# YAMPI_TOKEN=seu_token_yampi
# YAMPI_ALIAS=seu_alias_yampi (ex.: vanessa-lima)
# YAMPI_WEBHOOK_TOKEN=token_validacao_webhook (opcional)

# ------------------------------------------------------------
# APPMAX (apenas Edge Functions)
# Configurar via: supabase secrets set APPMAX_API_KEY=...
# ------------------------------------------------------------
# APPMAX_API_KEY=sua_api_key_appmax

# ------------------------------------------------------------
# BLING ERP (apenas Edge Functions)
# Configurar via: supabase secrets set BLING_CLIENT_ID=...
# ------------------------------------------------------------
# BLING_CLIENT_ID=seu_client_id_bling
# BLING_CLIENT_SECRET=seu_client_secret_bling

# ------------------------------------------------------------
# CORS (opcional – Edge Functions)
# Lista de origens extras permitidas, separadas por vírgula.
# Use * para permitir qualquer origem (apenas em desenvolvimento).
# Configurar via: supabase secrets set CORS_ALLOWED_ORIGINS=...
# ------------------------------------------------------------
# CORS_ALLOWED_ORIGINS=https://meu-dominio.com,https://preview.meu-dominio.com

# ------------------------------------------------------------
# CONFIGURAÇÕES DE DESENVOLVIMENTO LOCAL
# ------------------------------------------------------------
# URL local do Supabase (ao usar supabase start)
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_PUBLISHABLE_KEY=sua_anon_key_local
