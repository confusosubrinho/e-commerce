# ============================================================
# AMBIENTE LOCAL – Supabase rodando na sua máquina
# ============================================================
# Copie para .env.local e preencha com os valores de:
#   npx supabase status
# (após rodar "npx supabase start" na raiz do projeto)
#
# Não commite .env.local. Ver docs/LOCAL_DEVELOPMENT.md.
# ============================================================

# Cole aqui o "API URL" (ex.: http://127.0.0.1:54321)
VITE_SUPABASE_URL=http://127.0.0.1:54321

# Cole aqui o "anon key" (string longa que começa com eyJ...)
VITE_SUPABASE_PUBLISHABLE_KEY=

# Necessário para seed:qa e testes E2E (cole o "service_role key")
SUPABASE_SERVICE_ROLE_KEY=
